# Function to evaluate the conclusion of a logic sentence given the premises
def evaluate(premises, conclusion):
    # convert to logic.
    logic = sentences_to_logic(premises)
    # evaluate the logic sentence.
    evaluation = logic.evaluate(conclusion)
    # return the evaluation result.
    return evaluation


# Function to evaluate the premises of a logic sentence given the conclusion
def evaluate_reverse(conclusion, premises):
    # convert to logic.
    logic = sentences_to_logic(premises)
    # evaluate the logic sentence.
    evaluation = logic.evaluate(conclusion)
    # return the evaluation result.
    return evaluation


# Function to test a sentence
def test(sentence):
    print(sentence)
    premises = [sentence]
    conclusion = 'True'
    print('Premises:'+ str(premises))
    print('Conclusion:'+ conclusion)
    evaluation = evaluate(premises, conclusion)
    print('Evaluation:'+ str(evaluation))
    print()


