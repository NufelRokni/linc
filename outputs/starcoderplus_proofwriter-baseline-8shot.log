def read_input(file_name: str) -> list:
    with open(file_name, "r") as f:
        lines = f.readlines()
        lines = [line.strip() for line in lines]
        return lines

def read_premises(lines: list) -> list:
    premises = []
    for line in lines:
        premises.append(nltk.fol.parse_sents(line))
    return premises

def read_conclusion(lines: list) -> nltk.fol.sent:
    return nltk.fol.parse_sents(lines[-1])

def get_variables(premises: list) -> set:
    variables = set()
    for premise in premises:
        variables.update(premise.vars)
    return variables

def get_schema(premises: list) -> list:
